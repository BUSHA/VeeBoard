{
	"name": "veeboard-api",
	"main": "src/index.js",
	"compatibility_date": "2026-05-26",
	"assets": {
		"directory": "./public",
		"not_found_handling": "single-page-application",
		"run_worker_first": [
			"/load",
			"/auth",
			"/signup",
			"/profile",
			"/users",
			"/user",
			"/save",
			"/upload",
			"/image",
			"/delete-image",
			"/boards",
			"/boards-for-login",
			"/board-session",
			"/user-board-access"
		]
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "veeboard_db",
			"database_id": "REPLACE_WITH_YOUR_D1_DATABASE_ID"
		}
	],
	"r2_buckets": [
		{
			"binding": "BUCKET",
			"bucket_name": "veeboard-attachments"
		}
	]
}
