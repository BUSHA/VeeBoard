{
	"name": "veeboard-api",
	"main": "src/index.js",
	"compatibility_date": "2024-03-01",
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "veeboard_db",
			"database_id": "REPLACE_WITH_YOUR_D1_DATABASE_ID"
		}
	],
	"r2_buckets": [
		{
			"binding": "BUCKET",
			"bucket_name": "veeboard-attachments"
		}
	]
}